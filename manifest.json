{
  "manifest_version": 3,
  "name": "myself",
  "version": "1.1.0",
  "description": "防分心专注插件 —— 动态黑名单 + 软性拦截",
  "permissions": ["storage", "tabs", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "myself - 专注模式"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
